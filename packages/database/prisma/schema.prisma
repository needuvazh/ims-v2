generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  Draft
  Active
  Inactive
  Archived
}

enum BranchStatus {
  Draft
  Configured
  Active
  UnderMaintenance
  Suspended
  Closed
  Archived
}

enum UserStatus {
  PendingActivation
  Active
  Locked
  Suspended
  Archived
}

enum PermissionType {
  Module
  Menu
  Action
  Report
}

model Person {
  id          String    @id @default(uuid()) @db.Uuid
  firstName   String    @db.VarChar(100)
  lastName    String    @db.VarChar(100)
  mobile      String    @unique @db.VarChar(30)
  email       String?   @unique @db.VarChar(255)
  nationalId  String?   @db.VarChar(50)
  nationality String?   @db.VarChar(50)
  dateOfBirth DateTime? @db.Date
  gender      String?   @db.VarChar(20)

  user User?
  leads Lead[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@map("persons")
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  personId          String     @unique @db.Uuid
  username          String     @unique @db.VarChar(100)
  email             String     @unique @db.VarChar(255)
  passwordHash      String     @db.Text
  userType          String     @db.VarChar(50)
  status            UserStatus @default(Active)
  defaultBranchId   String?    @db.Uuid
  preferredLanguage String     @default("en") @db.VarChar(10)
  lastLoginAt       DateTime?  @db.Timestamptz(6)

  // Security & lockout fields
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime? @db.Timestamptz(6)
  passwordChangedAt DateTime? @db.Timestamptz(6)
  version           Int       @default(1)

  // Effective dating
  effectiveStartDate DateTime  @default(now()) @db.Date
  effectiveEndDate   DateTime? @db.Date

  person           Person                @relation(fields: [personId], references: [id])
  roles            UserRole[]
  branchAccess     UserBranchAccess[]
  managedBranches  Branch[]              @relation("BranchManager")
  sessions         UserSession[]
  loginRecords     LoginHistory[]
  resetTokens      PasswordResetToken[]
  passwordHistory  PasswordHistory[]
  activationTokens UserActivationToken[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  leads     Lead[]         @relation("CounselorLeads")
  followUps LeadFollowUp[] @relation("CounselorFollowUps")
  inquiries Inquiry[]      @relation("CounselorInquiries")
  leadNotes LeadNote[]     @relation("AuthorNotes")
  stageChanges LeadStageHistory[] @relation("StageChanges")

  @@index([status])
  @@map("users")
}

model Role {
  id           String       @id @default(uuid()) @db.Uuid
  roleCode     String       @unique @db.VarChar(100)
  roleName     String       @unique @db.VarChar(150)
  description  String?      @db.Text
  isSystemRole Boolean      @default(false)
  version      Int          @default(1)
  status       RecordStatus @default(Active)

  // Effective dating
  effectiveStartDate DateTime  @default(now()) @db.Date
  effectiveEndDate   DateTime? @db.Date

  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@map("roles")
}

model Permission {
  id             String         @id @default(uuid()) @db.Uuid
  moduleCode     String         @db.VarChar(100)
  featureCode    String         @db.VarChar(100)
  actionCode     String         @db.VarChar(100)
  permissionCode String         @unique @db.VarChar(150)
  permissionType PermissionType @default(Action)
  description    String?        @db.Text
  status         RecordStatus   @default(Active)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  createdBy String?  @db.Uuid

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  roleId String @db.Uuid

  status                 String    @default("Active") @db.VarChar(50) // "Active", "Revoked"
  revokedAt              DateTime? @db.Timestamptz(6)
  revokedBy              String?   @db.Uuid
  reason                 String?   @db.Text

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserBranchAccess {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @db.Uuid
  branchId               String    @db.Uuid
  isDefault              Boolean   @default(false)
  includeChildBranches   Boolean   @default(false)
  consolidatedVisibility Boolean   @default(false)
  status                 String    @db.VarChar(50) // "Active", "Revoked"
  revokedAt              DateTime? @db.Timestamptz(6)
  revokedBy              String?   @db.Uuid
  reason                 String?   @db.Text

  user   User   @relation(fields: [userId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid

  @@unique([userId, branchId])
  @@map("user_branch_access")
}

model PasswordHistory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  passwordHash String   @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_history")
}

model UserActivationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @db.Text
  expiresAt DateTime  @db.Timestamptz(6)
  status    String    @db.VarChar(50) // "Pending", "Used", "Expired"
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash, status])
  @@map("user_activation_tokens")
}

model SecurityPolicy {
  id                         String  @id @default(uuid()) @db.Uuid
  maxFailedAttempts          Int     @default(5)
  lockoutDurationMinutes     Int     @default(30)
  passwordMinLength          Int     @default(8)
  passwordRequireUppercase   Boolean @default(true)
  passwordRequireLowercase   Boolean @default(true)
  passwordRequireNumbers     Boolean @default(true)
  passwordRequireSpecial     Boolean @default(true)
  passwordHistoryCount       Int     @default(5)
  passwordExpiryDays         Int     @default(90)
  resetTokenExpiryMinutes    Int     @default(15)
  accessTokenExpiryMinutes   Int     @default(15)
  refreshTokenExpiryDays     Int     @default(7)
  rememberMeRefreshTokenDays Int     @default(30)
  sessionInactivityMinutes   Int     @default(30)
  maxConcurrentSessions      Int     @default(3)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @db.Timestamptz(6)

  @@map("security_policies")
}

model Notification {
  id               String    @id @default(uuid()) @db.Uuid
  type             String    @db.VarChar(100)
  recipientUserId  String?   @db.Uuid
  recipientEmail   String    @db.VarChar(255)
  subject          String    @db.VarChar(255)
  body             String    @db.Text
  status           String    @db.VarChar(50) // "Pending", "Sent", "Failed"
  metadata         Json?
  providerResponse Json?
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime? @db.Timestamptz(6)

  @@map("notifications")
}

model ExportJob {
  id           String    @id @default(uuid()) @db.Uuid
  reportType   String    @db.VarChar(150)
  requestedBy  String    @db.Uuid
  branchId     String?   @db.Uuid
  filters      Json?
  format       String    @db.VarChar(50) // "CSV", "XLSX", "PDF"
  status       String    @db.VarChar(50) // "Pending", "Processing", "Done", "Failed"
  fileUrl      String?   @db.Text
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime? @db.Timestamptz(6)

  @@map("export_jobs")
}

model UserSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  tokenHash      String   @unique @db.Text
  previousTokenHash String? @db.Text
  userAgent      String?  @db.Text
  ipAddress      String?  @db.VarChar(45)
  status         String   @db.VarChar(50) // "Active", "Expired", "Revoked"
  expiresAt      DateTime @db.Timestamptz(6)
  lastAccessAt   DateTime @db.Timestamptz(6)
  activeBranchId String?  @db.Uuid

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([previousTokenHash])
  @@map("user_sessions")
}

model LoginHistory {
  id             String   @id @default(uuid()) @db.Uuid
  attemptedEmail String   @db.VarChar(255)
  userId         String?  @db.Uuid
  ipAddress      String?  @db.VarChar(45)
  userAgent      String?  @db.Text
  browser        String?  @db.VarChar(100)
  os             String?  @db.VarChar(100)
  device         String?  @db.VarChar(100)
  status         String   @db.VarChar(50) // "Success", "Failure"
  failureReason  String?  @db.VarChar(150)
  branchId       String?  @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@index([attemptedEmail])
  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model Institute {
  id                 String       @id @default(uuid()) @db.Uuid
  instituteCode      String       @unique @db.VarChar(50)
  instituteName      String       @db.VarChar(255)
  registrationNumber String?      @db.VarChar(100)
  taxNumber          String?      @db.VarChar(100)
  primaryEmail       String?      @db.VarChar(255)
  primaryPhone       String?      @db.VarChar(30)
  website            String?      @db.VarChar(255)
  address            String?      @db.Text
  country            String?      @db.VarChar(100)
  status             RecordStatus @default(Active)

  legalNameEnglish   String?      @db.VarChar(255)
  legalNameArabic    String?      @db.VarChar(255)
  tradeName          String?      @db.VarChar(255)
  shortName          String?      @db.VarChar(100)
  effectiveStartDate DateTime?    @db.Date
  effectiveEndDate   DateTime?    @db.Date
  currency           String?      @db.VarChar(10)
  timezone           String?      @db.VarChar(50)
  language           String?      @db.VarChar(10)

  branches Branch[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@map("institutes")
}

model Branch {
  id                 String       @id @default(uuid()) @db.Uuid
  instituteId        String       @db.Uuid
  branchCode         String       @db.VarChar(50)
  branchName         String       @db.VarChar(200)
  address            String?      @db.Text
  city               String?      @db.VarChar(100)
  country            String?      @db.VarChar(100)
  phone              String?      @db.VarChar(30)
  email              String?      @db.VarChar(255)
  branchManagerId    String?      @db.Uuid
  status             BranchStatus @default(Active)
  effectiveStartDate DateTime?    @db.Date
  effectiveEndDate   DateTime?    @db.Date

  parentBranchId     String?      @db.Uuid
  parentBranch       Branch?      @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  childBranches      Branch[]     @relation("BranchHierarchy")

  institute     Institute    @relation(fields: [instituteId], references: [id])
  branchManager User?        @relation("BranchManager", fields: [branchManagerId], references: [id])
  departments   Department[]
  classrooms    Classroom[]

  contacts      BranchContact[]
  addresses     BranchAddress[]
  settings      BranchSettings?
  policies      BranchPolicy[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  leads              Lead[]
  admissions         Admission[]
  inquiries          Inquiry[]
  userBranchAccesses UserBranchAccess[]

  @@unique([branchCode])
  @@index([status])
  @@index([city])
  @@index([instituteId])
  @@map("branches")
}

model BranchContact {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String   @db.Uuid
  contactType String   @db.VarChar(50)
  contactValue String  @db.VarChar(255)
  isPrimary   Boolean  @default(false)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  createdBy   String?  @db.Uuid
  updatedAt   DateTime? @db.Timestamptz(6)
  updatedBy   String?  @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(6)
  deletedBy   String?  @db.Uuid
  isDeleted   Boolean  @default(false)

  @@map("branch_contacts")
}

model BranchAddress {
  id           String   @id @default(uuid()) @db.Uuid
  branchId     String   @db.Uuid
  building     String?  @db.VarChar(100)
  street       String?  @db.VarChar(255)
  city         String?  @db.VarChar(100)
  governorate  String?  @db.VarChar(100)
  country      String?  @db.VarChar(100)
  postalCode   String?  @db.VarChar(30)
  latitude     Float?
  longitude    Float?
  mapUrl       String?  @db.Text
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  createdBy    String?  @db.Uuid
  updatedAt    DateTime? @db.Timestamptz(6)
  updatedBy    String?  @db.Uuid
  deletedAt    DateTime? @db.Timestamptz(6)
  deletedBy    String?  @db.Uuid
  isDeleted    Boolean  @default(false)

  @@map("branch_addresses")
}

model BranchSettings {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String   @unique @db.Uuid
  currency        String?  @db.VarChar(10)
  timezone        String?  @db.VarChar(50)
  weekStartDay    String?  @db.VarChar(20)
  workingCalendar String?  @db.VarChar(100)
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  createdBy       String?  @db.Uuid
  updatedAt       DateTime? @db.Timestamptz(6)
  updatedBy       String?  @db.Uuid
  deletedAt       DateTime? @db.Timestamptz(6)
  deletedBy       String?  @db.Uuid
  isDeleted       Boolean  @default(false)

  @@map("branch_settings")
}

model BranchPolicy {
  id            String   @id @default(uuid()) @db.Uuid
  branchId      String   @db.Uuid
  policyType    String   @db.VarChar(50)
  policyContent String?  @db.Text
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  createdBy     String?  @db.Uuid
  updatedAt     DateTime? @db.Timestamptz(6)
  updatedBy     String?  @db.Uuid
  deletedAt     DateTime? @db.Timestamptz(6)
  deletedBy     String?  @db.Uuid
  isDeleted     Boolean  @default(false)

  @@map("branch_policies")
}

model Department {
  id                 String       @id @default(uuid()) @db.Uuid
  branchId           String       @db.Uuid
  departmentCode     String       @db.VarChar(50)
  departmentName     String       @db.VarChar(200)
  departmentHeadId   String?      @db.Uuid
  description        String?      @db.Text
  status             RecordStatus @default(Active)
  effectiveStartDate DateTime?    @db.Date
  effectiveEndDate   DateTime?    @db.Date

  branch Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@unique([branchId, departmentCode])
  @@map("departments")
}

model Classroom {
  id                 String       @id @default(uuid()) @db.Uuid
  branchId           String       @db.Uuid
  classroomName      String       @db.VarChar(150)
  capacity           Int
  location           String?      @db.VarChar(255)
  status             RecordStatus @default(Active)
  effectiveStartDate DateTime?    @db.Date
  effectiveEndDate   DateTime?    @db.Date

  branch Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@unique([branchId, classroomName])
  @@map("classrooms")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  performedBy   String?  @db.Uuid
  performedAt   DateTime @default(now()) @db.Timestamptz(6)
  entityType    String   @db.VarChar(150)
  entityId      String   @db.VarChar(150)
  action        String   @db.VarChar(150)
  oldValue      Json?
  newValue      Json?
  ipAddress     String?  @db.VarChar(45)
  userAgent     String?  @db.Text
  branchId      String?  @db.Uuid
  correlationId String?  @db.VarChar(100)
  reason        String?  @db.Text
  module        String?  @db.VarChar(100)

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([performedAt])
  @@index([branchId])
  @@map("audit_logs")
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  eventType     String    @db.VarChar(150)
  aggregateType String    @db.VarChar(150)
  aggregateId   String    @db.VarChar(150)
  payload       Json
  status        String    @default("Pending") @db.VarChar(50)
  availableAt   DateTime  @db.Timestamptz(6)
  processedAt   DateTime? @db.Timestamptz(6)
  attempts      Int       @default(0)
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  @@index([status, availableAt])
  @@map("outbox_events")
}

enum LeadStage {
  New
  Contacted
  FollowUp
  Qualified
  Negotiation
  Won
  Converted
  Lost
}

enum LeadSource {
  WalkIn
  Web
  Campaign
  Referral
  Other
  Phone
  WhatsApp
  Facebook
  Instagram
  GoogleAds
  CorporateReferral
}

model Campaign {
  id                 String    @id @default(uuid()) @db.Uuid
  campaignName       String    @unique @db.VarChar(150)
  campaignType       String    @db.VarChar(50)
  utmSource          String    @db.VarChar(100)
  utmMedium          String    @db.VarChar(100)
  utmCampaign        String    @db.VarChar(100)
  budget             Decimal   @db.Decimal(12, 3)
  effectiveStartDate DateTime  @db.Date
  effectiveEndDate   DateTime? @db.Date
  status             String    @default("Active") @db.VarChar(50)
  
  leads              Lead[]

  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  createdBy          String?   @db.Uuid
  updatedAt          DateTime? @db.Timestamptz(6)
  updatedBy          String?   @db.Uuid
  deletedAt          DateTime? @db.Timestamptz(6)
  isDeleted          Boolean   @default(false)

  @@unique([utmSource, utmMedium, utmCampaign])
  @@map("campaigns")
}

model CourseCategory {
  id               String           @id @default(uuid()) @db.Uuid
  code             String           @unique @db.VarChar(100)
  nameEnglish      String           @db.VarChar(150)
  nameArabic       String           @db.VarChar(150)
  description      String?          @db.Text
  parentCategoryId String?          @db.Uuid
  parentCategory   CourseCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  childCategories  CourseCategory[] @relation("CategoryHierarchy")
  courses          Course[]

  status           RecordStatus     @default(Active)
  version          Int              @default(1)

  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  createdBy        String?          @db.Uuid
  updatedAt        DateTime?        @updatedAt @db.Timestamptz(6)
  updatedBy        String?          @db.Uuid
  deletedAt        DateTime?        @db.Timestamptz(6)
  deletedBy        String?          @db.Uuid
  isDeleted        Boolean          @default(false)

  @@map("course_categories")
}

model CoursePricing {
  id                 String       @id @default(uuid()) @db.Uuid
  courseId           String       @db.Uuid
  course             Course       @relation(fields: [courseId], references: [id])
  branchId           String?      @db.Uuid // logical reference; NULL = Global Default
  batchId            String?      @db.Uuid // FK reference; NULL = Global/Branch override
  batch              Batch?       @relation(fields: [batchId], references: [id])
  customerType       String       @db.VarChar(50) // Individual, Corporate, WalkIn
  batchType          String       @db.VarChar(50) // Regular, FastTrack, Weekend
  currency           String       @default("OMR") @db.VarChar(10) // Restricted to OMR
  basePrice          Decimal      @db.Decimal(12, 3)
  taxPercentage      Decimal      @default(5.000) @db.Decimal(5, 3) // Oman Standard VAT
  effectiveStartDate DateTime     @db.Date
  effectiveEndDate   DateTime?    @db.Date
  status             RecordStatus @default(Active)
  version            Int          @default(1)

  createdAt          DateTime     @default(now()) @db.Timestamptz(6)
  createdBy          String?      @db.Uuid
  updatedAt          DateTime?    @updatedAt @db.Timestamptz(6)
  updatedBy          String?      @db.Uuid
  deletedAt          DateTime?    @db.Timestamptz(6)
  deletedBy          String?      @db.Uuid
  isDeleted          Boolean      @default(false)

  @@index([courseId])
  @@index([branchId])
  @@index([batchId])
  @@map("course_pricings")
}

model CourseDiscount {
  id                 String       @id @default(uuid()) @db.Uuid
  courseId           String       @db.Uuid
  course             Course       @relation(fields: [courseId], references: [id])
  branchId           String?      @db.Uuid // logical reference; NULL = Global
  batchId            String?      @db.Uuid // FK reference; NULL = Global/Branch
  batch              Batch?       @relation(fields: [batchId], references: [id])
  discountType       String       @db.VarChar(50) // Individual, Corporate, EarlyBird
  discountMode       String       @db.VarChar(50) // Percentage, FixedAmount
  discountValue      Decimal      @db.Decimal(12, 3)
  requiresApproval   Boolean      @default(false)
  effectiveStartDate DateTime     @db.Date
  effectiveEndDate   DateTime?    @db.Date
  status             RecordStatus @default(Active)

  createdAt          DateTime     @default(now()) @db.Timestamptz(6)
  createdBy          String?      @db.Uuid
  updatedAt          DateTime?    @updatedAt @db.Timestamptz(6)
  updatedBy          String?      @db.Uuid
  deletedAt          DateTime?    @db.Timestamptz(6)
  deletedBy          String?      @db.Uuid
  isDeleted          Boolean      @default(false)

  @@index([courseId])
  @@index([branchId])
  @@index([batchId])
  @@map("course_discounts")
}

model CourseCompletionRule {
  id                       String       @id @default(uuid()) @db.Uuid
  courseId                 String       @db.Uuid
  course                   Course       @relation(fields: [courseId], references: [id])
  minimumAttendancePercent Int          @db.Integer
  examRequired             Boolean      @default(false)
  feeClearanceRequired     Boolean      @default(true)
  manualApprovalRequired   Boolean      @default(false)
  effectiveStartDate       DateTime     @db.Date
  effectiveEndDate         DateTime?    @db.Date
  status                   RecordStatus @default(Active)

  createdAt                DateTime     @default(now()) @db.Timestamptz(6)
  createdBy                String?      @db.Uuid
  updatedAt                DateTime?    @updatedAt @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@index([courseId])
  @@map("course_completion_rules")
}

model Course {
  id                    String                 @id @default(uuid()) @db.Uuid
  courseCode            String                 @unique @db.VarChar(50)
  nameEnglish           String                 @db.VarChar(150)
  nameArabic            String                 @db.VarChar(150)
  descriptionEnglish    String?                @db.Text
  descriptionArabic     String?                @db.Text
  departmentId          String                 @db.Uuid
  categoryId            String?                @db.Uuid
  courseClassification  String                 @db.VarChar(50)
  durationType          String                 @db.VarChar(50)
  durationValue         Int
  allowWalkInCompletion Boolean                @default(false)
  status                String                 @default("Draft") @db.VarChar(50) // Draft, InReview, Approved, Published, Archived
  
  effectiveStartDate    DateTime               @db.Date
  effectiveEndDate      DateTime?              @db.Date

  version               Int                    @default(1)

  category              CourseCategory?        @relation(fields: [categoryId], references: [id])
  pricings              CoursePricing[]
  completionRules       CourseCompletionRule[]
  discounts             CourseDiscount[]
  batches               Batch[]

  leads                 Lead[]
  inquiries             Inquiry[]

  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  createdBy             String?                @db.Uuid
  updatedAt             DateTime?              @updatedAt @db.Timestamptz(6)
  updatedBy             String?                @db.Uuid
  deletedAt             DateTime?              @db.Timestamptz(6)
  deletedBy             String?                @db.Uuid
  isDeleted             Boolean                @default(false)

  @@index([categoryId])
  @@index([departmentId])
  @@map("courses")
}

model Batch {
  id                     String           @id @default(uuid()) @db.Uuid
  courseId               String           @db.Uuid
  course                 Course           @relation(fields: [courseId], references: [id])
  branchId               String           @db.Uuid // logical reference
  classroomId            String?          @db.Uuid // logical reference
  batchCode              String           @unique @db.VarChar(50)
  batchNameEnglish       String           @db.VarChar(150)
  batchNameArabic        String           @db.VarChar(150)
  startDate              DateTime         @db.Date
  endDate                DateTime         @db.Date
  capacity               Int              @db.Integer
  currentEnrollmentCount Int              @default(0) @db.Integer
  waitingListEnabled     Boolean          @default(true)
  allowOverbooking       Boolean          @default(false)
  isWalkIn               Boolean          @default(false)
  corporateAccountId     String?          @db.Uuid // logical reference
  status                 String           @db.VarChar(50) // Draft, OpenForEnrollment, InProgress, Completed, Cancelled
  version                Int              @default(1)

  trainers               BatchTrainer[]
  sessions               Session[]
  waitlist               WaitingList[]
  pricings               CoursePricing[]
  discounts              CourseDiscount[]

  createdAt              DateTime         @default(now()) @db.Timestamptz(6)
  createdBy              String?          @db.Uuid
  updatedAt              DateTime?        @updatedAt @db.Timestamptz(6)
  updatedBy              String?          @db.Uuid
  deletedAt              DateTime?        @db.Timestamptz(6)
  deletedBy              String?          @db.Uuid
  isDeleted              Boolean          @default(false)

  @@index([courseId])
  @@index([branchId])
  @@index([classroomId])
  @@index([corporateAccountId])
  @@map("batches")
}

model BatchTrainer {
  id             String    @id @default(uuid()) @db.Uuid
  batchId        String    @db.Uuid
  batch          Batch     @relation(fields: [batchId], references: [id])
  trainerId      String    @db.Uuid // logical reference
  role           String    @db.VarChar(50) // Primary, Assistant, Observer
  assignedFrom   DateTime  @db.Date
  assignedTo     DateTime  @db.Date
  status         String    @default("Active") @db.VarChar(50)

  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  createdBy      String?   @db.Uuid
  updatedAt      DateTime? @updatedAt @db.Timestamptz(6)
  updatedBy      String?   @db.Uuid
  deletedAt      DateTime? @db.Timestamptz(6)
  deletedBy      String?   @db.Uuid
  isDeleted      Boolean   @default(false)

  @@index([batchId])
  @@index([trainerId])
  @@map("batch_trainers")
}

model WaitingList {
  id            String    @id @default(uuid()) @db.Uuid
  courseId      String    @db.Uuid
  batchId       String    @db.Uuid
  batch         Batch     @relation(fields: [batchId], references: [id])
  studentId     String?   @db.Uuid // logical reference
  leadId        String?   @db.Uuid // logical reference
  queuePosition Int       @db.Integer
  status        String    @db.VarChar(50) // Waiting, Promoted, Removed

  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  createdBy     String?   @db.Uuid
  updatedAt     DateTime? @updatedAt @db.Timestamptz(6)
  updatedBy     String?   @db.Uuid
  deletedAt     DateTime? @db.Timestamptz(6)
  deletedBy     String?   @db.Uuid
  isDeleted     Boolean   @default(false)

  @@index([courseId])
  @@index([batchId])
  @@index([studentId])
  @@index([leadId])
  @@unique([studentId, batchId, status]) // Standard constraint to prevent duplicate active waitlist entries
  @@unique([leadId, batchId, status]) // Standard constraint to prevent duplicate active waitlist entries
  @@map("waiting_lists")
}

model Session {
  id            String    @id @default(uuid()) @db.Uuid
  batchId       String    @db.Uuid
  batch         Batch     @relation(fields: [batchId], references: [id])
  sessionNumber Int       @db.Integer
  titleEnglish  String    @db.VarChar(150)
  titleArabic   String    @db.VarChar(150)
  sessionDate   DateTime  @db.Date
  startTime     String    @db.VarChar(10) // HH:MM
  endTime       String    @db.VarChar(10) // HH:MM
  trainerId     String?   @db.Uuid // logical reference
  classroomId   String?   @db.Uuid // logical reference
  status        String    @db.VarChar(50) // Scheduled, Completed, Cancelled, Rescheduled
  version       Int       @default(1)

  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  createdBy     String?   @db.Uuid
  updatedAt     DateTime? @updatedAt @db.Timestamptz(6)
  updatedBy     String?   @db.Uuid
  deletedAt     DateTime? @db.Timestamptz(6)
  deletedBy     String?   @db.Uuid
  isDeleted     Boolean   @default(false)

  @@index([batchId])
  @@index([trainerId])
  @@index([classroomId])
  @@index([sessionDate])
  @@map("sessions")
}

model Inquiry {
  id                 String    @id @default(uuid()) @db.Uuid
  inquiryNumber      String    @unique @db.VarChar(50)
  branchId           String    @db.Uuid
  firstName          String    @db.VarChar(100)
  lastName           String    @db.VarChar(100)
  mobile             String    @db.VarChar(30)
  email              String?   @db.VarChar(255)
  source             LeadSource @default(Other)
  interestedCourseId String?   @db.Uuid
  counselorId        String?   @db.Uuid
  priority           String    @default("Medium") @db.VarChar(20)
  notes              String?   @db.Text
  status             String    @default("Captured") @db.VarChar(50)
  isDuplicate        Boolean   @default(false)
  duplicateRefId     String?   @db.VarChar(150)
  utmSource          String?   @db.VarChar(100)
  utmMedium          String?   @db.VarChar(100)
  utmCampaign        String?   @db.VarChar(100)

  branch             Branch    @relation(fields: [branchId], references: [id])
  counselor          User?     @relation("CounselorInquiries", fields: [counselorId], references: [id])
  interestedCourse   Course?   @relation(fields: [interestedCourseId], references: [id])
  leads              Lead[]

  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  createdBy          String?   @db.Uuid
  updatedAt          DateTime? @updatedAt @db.Timestamptz(6)
  updatedBy          String?   @db.Uuid
  deletedAt          DateTime? @db.Timestamptz(6)
  deletedBy          String?   @db.Uuid
  isDeleted          Boolean   @default(false)

  @@index([branchId])
  @@index([counselorId])
  @@index([status])
  @@map("inquiries")
}

model Lead {
  id                 String         @id @default(uuid()) @db.Uuid
  leadNumber         String         @unique @db.VarChar(50)
  personId           String         @db.Uuid
  branchId           String         @db.Uuid
  firstName          String         @db.VarChar(100)
  lastName           String         @db.VarChar(100)
  email              String?        @db.VarChar(255)
  phone              String         @db.VarChar(30)
  stage              LeadStage      @default(New)
  source             LeadSource     @default(Other)
  counselorId        String?        @db.Uuid
  interestedCourseId String         @db.Uuid
  campaignId         String?        @db.Uuid
  priority           String         @default("Medium") @db.VarChar(20)
  notes              String?        @db.Text
  lostReasonCode     String?        @db.VarChar(50)
  lostReasonNotes    String?        @db.Text
  inquiryId          String?        @db.Uuid
  version            Int            @default(1)
  nextFollowUpDate   DateTime?      @db.Timestamptz(6)

  person             Person         @relation(fields: [personId], references: [id])
  branch             Branch         @relation(fields: [branchId], references: [id])
  counselor          User?          @relation("CounselorLeads", fields: [counselorId], references: [id])
  campaign           Campaign?      @relation(fields: [campaignId], references: [id])
  inquiry            Inquiry?       @relation(fields: [inquiryId], references: [id])
  interestedCourse   Course         @relation(fields: [interestedCourseId], references: [id])
  followUps          LeadFollowUp[]
  notesRelation      LeadNote[]     @relation("LeadNotes")
  stageHistory       LeadStageHistory[] @relation("StageHistory")

  createdAt          DateTime       @default(now()) @db.Timestamptz(6)
  createdBy          String?        @db.Uuid
  updatedAt          DateTime?      @updatedAt @db.Timestamptz(6)
  updatedBy          String?        @db.Uuid
  deletedAt          DateTime?      @db.Timestamptz(6)
  deletedBy          String?        @db.Uuid
  isDeleted          Boolean        @default(false)
  status             RecordStatus   @default(Active)

  @@index([branchId])
  @@index([counselorId])
  @@index([stage])
  @@index([personId])
  @@map("leads")
}

model LeadFollowUp {
  id           String    @id @default(uuid()) @db.Uuid
  leadId       String    @db.Uuid
  counselorId  String    @db.Uuid
  followUpDate DateTime  @db.Timestamptz(6)
  followUpType String    @db.VarChar(50)
  notes        String?   @db.Text
  outcome      String?   @db.VarChar(50)
  status       String    @default("Scheduled") @db.VarChar(50)

  lead         Lead      @relation(fields: [leadId], references: [id])
  counselor    User      @relation("CounselorFollowUps", fields: [counselorId], references: [id])

  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  createdBy    String?   @db.Uuid
  updatedAt    DateTime? @db.Timestamptz(6)
  updatedBy    String?   @db.Uuid
  deletedAt    DateTime? @db.Timestamptz(6)
  deletedBy    String?   @db.Uuid
  isDeleted    Boolean   @default(false)

  @@index([leadId])
  @@index([counselorId])
  @@index([status])
  @@map("lead_follow_ups")
}

model Student {
  id            String       @id @default(uuid()) @db.Uuid
  firstName     String       @db.VarChar(100)
  lastName      String       @db.VarChar(100)
  email         String?      @unique @db.VarChar(255)
  phone         String?      @db.VarChar(30)
  studentNumber String       @unique @db.VarChar(50)
  status        RecordStatus @default(Active)

  admissions Admission[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@index([email])
  @@index([phone])
  @@map("students")
}

model Admission {
  id            String       @id @default(uuid()) @db.Uuid
  studentId     String       @db.Uuid
  branchId      String       @db.Uuid
  admissionDate DateTime     @default(now()) @db.Timestamptz(6)
  status        RecordStatus @default(Active)
  leadId        String?      @db.Uuid

  student Student @relation(fields: [studentId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  createdBy String?   @db.Uuid
  updatedAt DateTime? @db.Timestamptz(6)
  updatedBy String?   @db.Uuid
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?   @db.Uuid
  isDeleted Boolean   @default(false)

  @@index([studentId])
  @@index([branchId])
  @@map("admissions")
}

model LeadNote {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  createdBy String?  @db.Uuid

  lead   Lead  @relation("LeadNotes", fields: [leadId], references: [id])
  author User? @relation("AuthorNotes", fields: [createdBy], references: [id])

  @@index([leadId])
  @@map("lead_notes")
}

model LeadStageHistory {
  id              String    @id @default(uuid()) @db.Uuid
  leadId          String    @db.Uuid
  oldStage        LeadStage
  newStage        LeadStage
  lostReasonCode  String?   @db.VarChar(50)
  lostReasonNotes String?   @db.Text
  performedBy     String    @db.Uuid
  performedAt     DateTime  @default(now()) @db.Timestamptz(6)

  lead            Lead      @relation("StageHistory", fields: [leadId], references: [id])
  performer       User      @relation("StageChanges", fields: [performedBy], references: [id])

  @@index([leadId])
  @@map("lead_stage_history")
}
