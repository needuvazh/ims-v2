{
  "name": "@ims/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  },
  "dependencies": {
    "@ims/audit": "workspace:*",
    "@ims/identity-access": "workspace:*",
    "@ims/organization": "workspace:*",
    "@ims/shared-kernel": "workspace:*",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "ts-node": "^10.9.2"
  }
}
